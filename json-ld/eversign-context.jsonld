    },
    "businessId": {
      "@id": "eversign:business_id"
    },
    "sandbox": {
      "@id": "eversign:sandbox"
    },
    "document": {
      "@id": "eversign:document",
      "@type": "@id"
    },
    "template": {
      "@id": "eversign:template",
      "@type": "@id"
    },
    "signer": {
      "@id": "eversign:signer",
      "@type": "@id"
    },
    "file": {
      "@id": "eversign:file",
      "@type": "@id"
    },
    "bulkSendJob": {
      "@id": "eversign:bulk_send_job",
      "@type": "@id"
    },
    "auditTrail": {
      "@id": "eversign:audit_trail",
      "@type": "@id"
    },
    "webhook": {
      "@id": "eversign:webhook",
      "@type": "@id"
    },
    "business": {
      "@id": "eversign:business",
      "@type": "@id"
    },
    "signatureField": {
      "@id": "eversign:signature_field",
      "@type": "@id"
    },
    "initialsField": {
