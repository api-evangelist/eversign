  "@type": "WebAPI",
  "name": "Eversign API",
  "alternateName": "Xodo Sign API",
  "description": "RESTful JSON API for creating and sending documents for electronic signature, managing templates, uploading files, tracking audit trails, bulk sending via CSV, and receiving webhook event notifications for document lifecycle events.",
  "url": "https://eversign.com/api",
  "documentation": "https://eversign.com/api/documentation",
  "provider": {
    "@type": "Organization",
    "name": "Eversign / Xodo Sign",
    "url": "https://eversign.com",
    "sameAs": [
      "https://github.com/eversign",
      "https://twitter.com/geteversign",
      "https://www.linkedin.com/company/xodosign"
    ]
  },
  "termsOfService": "https://eversign.com/terms-of-service",
  "baseURL": {
    "@id": "baseURL",
    "@value": "https://api.eversign.com"
  }
}
